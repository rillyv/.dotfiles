#!/bin/bash

export DISPLAY=:0
export XAUTHORITY=/home/rillyv/.Xauthority

EXT_MON=$(xrandr | awk '/ connected/ && $1 ~ /^DP[0-9-]*$/ {print $1}')
INTERNAL_MON=$(xrandr | awk '/ connected/ && /eDP/ {print $1}')

if [ -n "$EXT_MON" ]; then
    xrandr --output "$INTERNAL_MON" --off \
           --output "$EXT_MON" --mode 2560x1440 --scale 1x1 --primary
else
    xrandr --output "$EXT_MON" --off \
           --output "$INTERNAL_MON" --mode 3072x1920 --scale 1x1 --primary
fi

